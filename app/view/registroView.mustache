<link rel="stylesheet" href="/public/estilosCrearCuenta.css"



<div class="contenedor-crear-cuenta">

<h2 class="titulo-crear-cuenta">Crear Cuenta</h2>

<form id="form-registro" action="/usuario/registrarUsuario" enctype="multipart/form-data" method="post">
    <label for="name" class="label-nombre">Nombre completo:</label>
    <input type="text" name="name" id="name" >
    {{#errores.name}}
      <p class="error">{{errores.name}}</p>
    {{/errores.name}}
    <br>

    <label for="year" class="label-fecha">Fecha de Nacimiento:</label>
    <input type="date" name="date" id="date" >
    {{#errores.date}}
          <p class="error">{{errores.date}}</p>
        {{/errores.date}}
        <br>

    <label for="sex" class="label-sexo">Sexo:</label>
    <select name="sex" id="sex" >
    <option value="" disabled selected>Selecciona una opción</option>
    <option value="masculino">Masculino</option>
    <option value="femenino">Femenino</option>
    <option value="decirlo">Prefiero no decirlo</option>
    </select>
    {{#errores.sex}}
          <p class="error">{{errores.sex}}</p>
        {{/errores.sex}}
        <br>

 <!-- style="width: 500px; height: 300px;" ESTILO DEL MAPA-->
    <div id="map" class="mapa"></div>
    <input type="hidden" name="pais" id="pais">
    <input type="hidden" name="ciudad" id="ciudad">

    <label for="mail" class="label-email">Email:</label>
    <input type="email" name="mail" id="mail" >
    {{#errores.mail}}
          <p class="error">{{errores.mail}}</p>
        {{/errores.mail}}
        <br>

    <label for="password" class="label-password">Contraseña:</label>
    <input type="password" name="password" id="password" >
    {{#errores.password}}
          <p class="error">{{errores.password}}</p>
        {{/errores.password}}
        <br>

    <label for="username" class="label-usuario">Nombre de Usuario:</label>
    <input type="text" name="username" id="username" >
    {{#errores.username}}
          <p class="error">{{errores.username}}</p>
        {{/errores.username}}
        <br>

    <label for="foto" class="label-foto"> Foto:</label>
    <input type="file" name="foto" id="foto">
    {{#errores.foto}}
          <p class="error">{{errores.foto}}</p>
        {{/errores.foto}}
        <br>

{{#error_message}}
    <p class="error">{{error_message}}</p>
{{/error_message}}
    <input type="submit" value="Crear cuenta" class="boton-crear">



</div>
</form>

